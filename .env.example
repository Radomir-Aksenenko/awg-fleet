# Cloudflare API token with Zone:DNS:Edit on the fleet's zone.
CF_API_TOKEN=

# Optional: path to state.json (defaults to ./state.json)
# AWGFLEET_STATE=state.json

# Web-panel authentication. Keep these only in a root-owned environment file;
# never commit the real values. PANEL_SESSION_SECRET must be at least 32 chars.
PANEL_USERNAME=admin
PANEL_PASSWORD=replace-with-a-long-random-password
PANEL_SESSION_SECRET=replace-with-at-least-32-random-characters
